{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "default_agent": "chief-operator",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask",
    "skill": "allow"
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".opencode/node_modules/**",
      "**/node_modules/**",
      "__MACOSX/**",
      "**/.DS_Store",
      "docs/db-audit/**",
      ".opencode/package-lock.json",
      ".opencode/package.json",
      "--meta_value=0"
    ]
  }
}
